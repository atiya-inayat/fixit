{
  "name": "fixit-server",
  "version": "1.0.0",
  "description": "FixIt backend - Express.js API server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --format=cjs",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "better-auth": "^1.2.0",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "groq-sdk": "^1.1.2",
    "mongodb": "^7.2.0",
    "mongoose": "^8.5.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
